# Telegram token from @BotFather
TELEGRAM_BOT_TOKEN=put_your_telegram_bot_token_here

# Optional. If absent, the prototype works in rule-based mode.
OPENAI_API_KEY=

# Narrative model. gpt-5.5 prioritizes quality; gpt-5.4-mini is a cheaper option.
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2

# SQLite DB path. Docker Compose overrides this with /app/data/providnyk.sqlite3.
GAME_DB_PATH=data/providnyk.sqlite3
DB_BUSY_TIMEOUT_MS=10000

# AI scenes are enabled by default in v9.
# Set false if you want strictly scripted scenes.
ENABLE_AI_SCENES=true

# Runtime
LOG_LEVEL=INFO
DROP_PENDING_UPDATES=false
